---
const titulo = "Litoral";
const subtitulo =
  "Espacio digital para proyectos, investigación, creación y cultura en torno al lenguaje, la literatura y los territorios.";
---

<section id="inicio" class="mx-auto grid max-w-6xl gap-12 px-6 py-20 md:grid-cols-2 md:items-center">
  <div>
    <p class="mb-4 text-sm uppercase tracking-[0.25em] text-zinc-400">
      Lenguaje · Literatura · Cultura
    </p>

    <h1 class="text-4xl font-bold leading-tight md:text-6xl">
      {titulo}
    </h1>

    <p class="mt-6 max-w-xl text-lg leading-8 text-zinc-300">
      {subtitulo}
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="#proyectos"
        class="rounded-xl bg-white px-5 py-3 font-semibold text-zinc-900 transition hover:scale-[1.02]"
      >
        Explorar
      </a>

      <a
        href="#contacto"
        class="rounded-xl border border-zinc-700 px-5 py-3 font-semibold transition hover:bg-zinc-800"
      >
        Contacto
      </a>
    </div>
  </div>

  <div class="rounded-3xl border border-zinc-800 bg-zinc-900 p-8 shadow-2xl">
    <div class="space-y-4">
      <div class="rounded-2xl bg-zinc-800/70 p-4">
        <h2 class="text-xl font-semibold">Investigación</h2>
        <p class="mt-2 text-zinc-300">
          Procesos académicos y críticos sobre lenguaje, literatura y cultura.
        </p>
      </div>

      <div class="rounded-2xl bg-zinc-800/70 p-4">
        <h2 class="text-xl font-semibold">Creación</h2>
        <p class="mt-2 text-zinc-300">
          Proyectos que articulan escritura, oralidad, memoria e imaginación.
        </p>
      </div>

      <div class="rounded-2xl bg-zinc-800/70 p-4">
        <h2 class="text-xl font-semibold">Territorio</h2>
        <p class="mt-2 text-zinc-300">
          Una mirada situada a las culturas, comunidades y narrativas locales.
        </p>
      </div>
    </div>
  </div>
</section>