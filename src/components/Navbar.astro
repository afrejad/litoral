---
const base = import.meta.env.BASE_URL;
const home = base;
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-zinc-950/70 backdrop-blur-xl">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={home} class="text-lg font-semibold tracking-[0.18em] text-white uppercase">
      Litoral
    </a>

    <ul class="hidden items-center gap-6 text-sm text-zinc-300 md:flex">
      <li><a href={home} class="transition hover:text-white">Inicio</a></li>
      <li><a href={`${base}sobre-mi`} class="transition hover:text-white">Sobre mí</a></li>
      <li><a href={`${home}#proyectos`} class="transition hover:text-white">Proyectos</a></li>
      <li><a href={`${home}#servicios`} class="transition hover:text-white">Líneas</a></li>
      <li><a href={`${home}#contacto`} class="transition hover:text-white">Contacto</a></li>
    </ul>
  </nav>
</header>